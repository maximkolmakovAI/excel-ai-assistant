[project]
name = "excel-ai-assistant"
version = "1.0.0"
description = "AI-powered assistant for analyzing Excel files with natural language"
requires-python = ">=3.11"
dependencies = [
    "streamlit>=1.55.0",
    "pandas>=2.0.0",
    "openpyxl>=3.10.0",
    "matplotlib>=3.7.0",
    "plotly>=5.0.0",
    "kaleido>=0.2.0",
    "fpdf2>=2.7.0",
    "xlsxwriter>=3.0.0",
    "openai>=1.0.0",
    "tenacity>=8.0.0",
]
